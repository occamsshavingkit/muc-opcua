{
  // Dev container for micro-opcua. Used by GitHub Codespaces and "Dev Containers" in VS Code.
  //
  // The point: a Codespaces *prebuild* runs `updateContentCommand` ahead of time and bakes the result
  // into the image, so a new codespace (or a rebuilt one) starts with the host build already configured
  // (Unity fetched via CMake FetchContent, the static lib + tests compiled) — no cold full build on first use.
  //
  // To get the "already compiled" benefit, enable a prebuild once in the repo:
  //   GitHub repo → Settings → Codespaces → "Set up prebuild" → branch main, this devcontainer.
  // Without a prebuild the container still works; the first `cmake --build` just runs normally.
  "name": "micro-opcua",
  "image": "mcr.microsoft.com/devcontainers/cpp:1-bookworm",

  // System tools the build + checks need (mirrors .github/workflows/ci.yml):
  //   - host build + tests: cmake, build-essential
  //   - static analysis / formatting: cppcheck, clang-tidy, clang-format
  //   - sanitizer + fuzzer builds: clang
  //   - RP2040/Pico cross-compile target: gcc-arm-none-eabi, libnewlib-arm-none-eabi
  //   - interop smoke test (tests/interop): python3 + asyncua (a standards OPC UA client)
  // (The cpp image ships cmake/clang/build-essential already; we install explicitly so the set is pinned.)
  "onCreateCommand": "sudo apt-get update && sudo apt-get install -y cmake build-essential cppcheck clang-tidy clang-format clang gcc-arm-none-eabi libnewlib-arm-none-eabi pkg-config python3-pip python3-venv && pip3 install --break-system-packages asyncua",

  // Heavy, cacheable work — runs during prebuild so the image ships warm:
  //   - configure + build the host target with tests and examples (this is what we keep repeating)
  //   - fetching Unity (CMake FetchContent) happens as part of the configure step above
  "updateContentCommand": "cmake -S . -B build/host -DMICRO_OPCUA_BUILD_TESTS=ON -DMICRO_OPCUA_BUILD_EXAMPLES=ON -DMICRO_OPCUA_PLATFORM=host && cmake --build build/host",

  "customizations": {
    "vscode": {
      "extensions": ["ms-vscode.cpptools-extension-pack", "ms-vscode.cmake-tools"]
    }
  }
}
