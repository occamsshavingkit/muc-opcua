<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <AssemblyName>InteropClient</AssemblyName>
    <RootNamespace>MicroOpcUa.Interop</RootNamespace>
    <InvariantGlobalization>true</InvariantGlobalization>
  </PropertyGroup>

  <ItemGroup>
    <!-- OPC Foundation UA-.NETStandard reference client (the stack the UACTT is built on).
         Pinned to match the async-opcua interop harness. -->
    <PackageReference Include="OPCFoundation.NetStandard.Opc.Ua.Client" Version="1.5.378.145" />
  </ItemGroup>

</Project>
