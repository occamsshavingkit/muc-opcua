# -- Internal profile cascade symbols (OPC-10000-7 §4.3) --------------
# Invisible bool symbols encoding the profile inclusion hierarchy.
# Selecting a higher named profile auto-activates all lower cascade
# symbols.  Facet / CU / capacity defaults reference the lowest internal
# profile symbol that reaches them.  custom has no cascade symbol.
# Each cascade symbol also implies the Facet toggles whose minimum
# profile matches this level so a profile switch re-seeds facet defaults.

config MUC_OPCUA_INTERN_PROFILE_FULL_EVERYTHING_ENABLED_GENEROUS_CAPACITIES
	bool
	default y if MUC_OPCUA_PROFILE_FULL_EVERYTHING_ENABLED_GENEROUS_CAPACITIES

