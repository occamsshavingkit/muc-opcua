config READ_CACHE
	bool "Read value cache (maxAge optimization)"
	default n
	help
	  Implementation state: implemented.
	  Notes: Opt-in Read value cache (maxAge optimization). Current build symbol but no dedicated conformance test; classified implemented, not claimed.

config SECURE_CHANNEL_CRYPTO
	bool "Secure channel message crypto"
	depends on MUC_OPCUA_FACET_CORE_2022_SERVER
	default y if MUC_OPCUA_INTERN_PROFILE_MICRO_EMBEDDED_DEVICE_2025_SERVER
	help
	  Implementation state: implemented.
	  OPC source: OPC-10000-7 §4.3.
	  Backing tests: test_secure_handshake_modern.
	  Notes: Build gate that decouples secure-channel message crypto (symmetric/asymmetric chunk crypto, certificate, trustlist, key derivation) from the MUC_OPCUA_FACET_CORE_2022_SERVER umbrella. Defaults off for nano (SecurityPolicy None only per OPC-10000-7 4.3) and on for the security-capable micro/embedded/standard/full profiles (profile intent, not backend presence -- spec 072 FR-005). When off the heavy crypto TUs are excluded and MUC_OPCUA_CU_SECURITY_ECC / crypto backends cannot be enabled; SecurityPolicy None behaviour and explicit non-None rejection are preserved.

endmenu

menu "Capacities"

# Capacity int symbols.  Defaults come from the manifest; legacy
# -DMU_MAX_*=N overrides are translated by CMakeLists.txt into
# MUC_OPCUA_<SYM>=N lines in the override fragment so the resolved
# value visible in .config / menuconfig matches the compile-time value.
# C sources still consume MU_INTERN_* macros from the generated
# include/muc_opcua/capacities.h (same default<profile<user cascade).

config MAX_SESSIONS
	int "Max sessions"
	default 100 if MUC_OPCUA_INTERN_PROFILE_FULL_EVERYTHING_ENABLED_GENEROUS_CAPACITIES
	default 50 if MUC_OPCUA_INTERN_PROFILE_STANDARD_2025_UA_SERVER
	default 2
	help
	  Capacity: max_sessions.
	  Public override: MU_MAX_SESSIONS (e.g. -DMU_MAX_SESSIONS=N).
	  Internal macro: MU_INTERN_MAX_SESSIONS.
	  Kind: profile_varying.
	  Valid range: >=1.
	  StandardUA2017 ServerProfileArray capacities.
	  Notes: Stage 1 baseline = nano.

config MAX_CONNECTIONS
	int "Max connections"
	default 100 if MUC_OPCUA_INTERN_PROFILE_FULL_EVERYTHING_ENABLED_GENEROUS_CAPACITIES
	default 50 if MUC_OPCUA_INTERN_PROFILE_STANDARD_2025_UA_SERVER
	default 4 if MUC_OPCUA_INTERN_PROFILE_EMBEDDED_2025_UA_SERVER
	default 2 if MUC_OPCUA_INTERN_PROFILE_MICRO_EMBEDDED_DEVICE_2025_SERVER
	default 1
	help
	  Capacity: max_connections.
	  Public override: MU_MAX_CONNECTIONS (e.g. -DMU_MAX_CONNECTIONS=N).
	  Internal macro: MU_INTERN_MAX_CONNECTIONS.
	  Kind: profile_varying.
	  Valid range: >=1.
	  MicroEmbeddedDevice2017 mandates >=2.
	  Notes: connections >= sessions; pool gated on MULTIPLE_CONNECTIONS.

