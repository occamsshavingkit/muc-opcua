	bool "CU: Base Info Type Information"
	depends on MUC_OPCUA_FACET_EXPOSES_TYPE_SYSTEM_SERVER
	default y if MUC_OPCUA_INTERN_PROFILE_EMBEDDED_2025_UA_SERVER
