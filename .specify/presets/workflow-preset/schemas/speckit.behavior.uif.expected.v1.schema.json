{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "speckit.behavior.uif.expected.v1.schema.json",
  "title": "Spec Kit Expected UIF Contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_type", "id", "source", "type", "start_view", "steps", "feedback_candidates"],
  "properties": {
    "contract_type": {
      "const": "speckit.behavior.uif.expected.v1"
    },
    "id": {"type": "string", "minLength": 1},
    "source": {"type": "string", "minLength": 1},
    "type": {"const": "expected"},
    "start_view": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "name": {"type": "string", "minLength": 1}
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["type"],
        "allOf": [
          {
            "if": {
              "properties": {"type": {"const": "api_call"}},
              "required": ["type"]
            },
            "then": {
              "required": ["api"]
            }
          },
          {
            "if": {
              "properties": {"type": {"const": "local_route"}},
              "required": ["type"]
            },
            "then": {
              "required": ["to"]
            }
          },
          {
            "if": {
              "properties": {"type": {"const": "user_event"}},
              "required": ["type"]
            },
            "then": {
              "anyOf": [
                {"required": ["id"]},
                {"required": ["label"]}
              ]
            }
          }
        ],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "type": {
            "enum": ["user_event", "local_route", "api_call", "external_link", "system_event"]
          },
          "label": {"type": "string", "minLength": 1},
          "to": {},
          "api": {
            "type": "object",
            "additionalProperties": false,
            "required": ["method", "path"],
            "properties": {
              "method": {"type": "string", "minLength": 1},
              "path": {"type": "string", "minLength": 1}
            }
          }
        }
      }
    },
    "feedback_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "message"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "type": {"type": "string", "minLength": 1},
          "message": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
